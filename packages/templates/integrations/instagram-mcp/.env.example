# Instagram MCP — gizli açarlar şablonu
#
# Bu faylı KOPYALA və `.env` adı ilə saxla, sonra real dəyərləri əlavə et.
# `.env` faylı gitignore-dadır — git-ə getmir.
#
# Yeni kompüterə keçdikdə: bu faylı `.env`-ə kopyala və real açarları
# köhnə kompüterdən (USB, password manager) və ya Meta Dashboard-dan yenidən çıxar.
#
# ⚠️ DİQQƏT: BU FAYLA HEÇLƏRİ DƏYƏR YAZMA. Real açarlar yalnız `.env`-ə.

# Meta App-ın əsas məlumatları
META_APP_ID="your_app_id_here"
META_APP_SECRET="your_app_secret_here"

# Instagram Business Account
IG_BUSINESS_ACCOUNT_ID="17841452855231512"
IG_USERNAME="azerogluemin_ai"

# Instagram Long-Lived Access Token (60 gün)
# Yenilənmə tarixi: meta-app-config.md-də qeyd olunur
IG_ACCESS_TOKEN="your_long_lived_token_here"

# Token yaradılma tarixi (yenilənməni izləmək üçün)
IG_TOKEN_CREATED_AT="YYYY-MM-DD"
IG_TOKEN_EXPIRES_AT="YYYY-MM-DD"
