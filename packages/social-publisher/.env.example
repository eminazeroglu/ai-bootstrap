# ============================================================
# Social Publisher — environment dəyişənləri
# Railway-də bu dəyərləri env vars olaraq təyin et (kodda YOX).
# ============================================================

# --- Server ---
PORT=3000
# API auth açarı. Boş buraxsan auth deaktiv olur (yalnız local test).
API_KEY=change-me-to-a-long-random-string

# Növbə JSON faylının yolu (Railway-də persistent volume tövsiyə olunur).
QUEUE_FILE=./data/queue.json
# Müştəri konfiqurasiya faylı (bax clients.example.json).
CLIENTS_FILE=./clients.json

# Cron loop intervalı (ms). Default 5 dəqiqə.
POLL_INTERVAL_MS=300000
# Uğursuz postun maksimum cəhd sayı.
MAX_ATTEMPTS=3

# ============================================================
# Müştəri tokenləri — clients.json-dakı env referansları ilə uyğun olmalıdır.
# ============================================================

# --- Default / tək müştəri (clients.json olmasa istifadə olunur) ---
# graph.instagram.com (Instagram Login API) — DÜZGÜN host.
# IGAA... ilə başlayan 60 günlük token.
INSTAGRAM_ACCESS_TOKEN=
# Instagram Business Account ID.
INSTAGRAM_ACCOUNT_ID=
# Token refresh üçün (Mərhələ 2 — opsional).
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# --- Sahil Transport (clients.json nümunəsinə uyğun) ---
SAHIL_INSTAGRAM_ACCESS_TOKEN=
SAHIL_INSTAGRAM_ACCOUNT_ID=

# ============================================================
# Ad Watcher — Meta reklam nəzarəti → Telegram bildiriş (opsional)
# Hər ikisi (Meta + Telegram) təyin olunmasa watcher deaktivdir.
# ============================================================

# Meta reklam icazəli token (ads_read). Meta MCP OAuth-dan alınır.
META_ACCESS_TOKEN=
# İzlənən reklam hesabları — vergüllə ayrılmış (act_ prefiksi lazım deyil).
META_AD_ACCOUNT_IDS=964182699719334,24446894524972112
# Graph API versiyası.
META_API_VERSION=v21.0
# Yoxlama intervalı (ms). Default 30 dəqiqə.
AD_WATCH_INTERVAL_MS=1800000

# --- Telegram bildiriş ---
# @BotFather-dan bot token.
TELEGRAM_BOT_TOKEN=
# Bildiriş gedən chat ID (bota "start" yazıb, getUpdates ilə alınır).
TELEGRAM_CHAT_ID=
