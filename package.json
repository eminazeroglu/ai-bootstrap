{
  "name": "ai-bootstrap-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Personal AI infrastructure bootstrap for Claude Code — root workspace",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "author": "Emin Azəroğlu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eminazeroglu/ai-bootstrap"
  }
}
